#include <stdio.h>

int main(){
    int n, arr[100];
    int i = 0, unsafe = 0, consec = 0, breakdown = -1;

    scanf("%d",&n);

    while(i < n){
        scanf("%d",&arr[i]);

        if(arr[i] > 70){
            unsafe++;
            consec++;

            if(consec == 3 && breakdown == -1)
                breakdown = i + 1;
        }
        else
            consec = 0;

        i++;
    }

    if(breakdown == -1)
        printf("Breakdown At Reading: Not Occurred\n");
    else
        printf("Breakdown At Reading: %d\n", breakdown);

    printf("Unsafe Readings: %d", unsafe);

    return 0;
}
