#include <stdio.h>
int main() {
    int N, i = 1;
    int login;
    int failedAttempts = 0;
    int consecutiveFail = 0;
    int lockAttempt = -1;
    scanf("%d", &N);
    while (i <= N) {
        scanf("%d", &login);
        if (login == 0) {
            failedAttempts++;
            consecutiveFail++;
            if (consecutiveFail == 3 && lockAttempt == -1) {
                lockAttempt = i;
            }
        } else {
            consecutiveFail = 0;
        }
        i++;
    }
    printf("Lock Triggered At Attempt: %d\n", lockAttempt);
    printf("Total Failed Attempts: %d\n", failedAttempts);
    return 0;
}
