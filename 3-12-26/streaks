#include <stdio.h>
int main() {
      int n;
    printf("Enter number of days: ");
    scanf("%d", &n);

    int arr[n];
    printf("Enter machine status (1 = working, 0 = failed):\n");

    int i = 0;
    while(i < n) {
        scanf("%d", &arr[i]);
        i++;
    }

    int currentStreak = 0;
    int maxStreak = 0;

    i = 0;
    while(i < n) {
        if(arr[i] == 0) {
            currentStreak++;
            if(currentStreak > maxStreak) {
                maxStreak = currentStreak;
            }
        } else {
            currentStreak = 0;
        }
        i++;
    }

    printf("Longest Failure Streak: %d\n", maxStreak);
    
    return 0;
}
