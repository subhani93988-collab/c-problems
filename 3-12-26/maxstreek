#include <stdio.h>
int main() {
    int N;
    int payment;
    int i = 0;
    int currentStreak = 0;
    int maxStreak = 0;
    scanf("%d", &N);
    while (i < N) {
        scanf("%d", &payment);

        if (payment == 0) {
            currentStreak++;   
            if (currentStreak > maxStreak) {
                maxStreak = currentStreak;
            }
        } else {
            currentStreak = 0; 
        }

        i++;
    }
    printf("Longest Default Streak: %d\n", maxStreak);
    return 0;
}
