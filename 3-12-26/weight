#include <stdio.h>
int main() {
     int maxWeight, N;
    int weight;
    int totalWeight = 0;
    int count = 0;
    int i = 0;
    scanf("%d", &maxWeight);
    scanf("%d", &N);
    while (i < N) {
        scanf("%d", &weight);

        if (totalWeight + weight > maxWeight) {
            break;   
        }
        totalWeight += weight;
        count++;
        i++;
    }
    printf("Passengers Allowed: %d\n", count);

    if (i < N) {
        printf("Overload: Yes\n");
    } else {
        printf("Overload: No\n");
    }
    return 0;
}
