#include <stdio.h>

int main(){
    int capacity, n, arr[100];
    int i = 0, treated = 0, rejected = 0;

    scanf("%d",&capacity);
    scanf("%d",&n);

    while(i < n){
        scanf("%d",&arr[i]);

        if(treated + arr[i] <= capacity)
            treated += arr[i];
        else{
            rejected += (treated + arr[i] - capacity);
            treated = capacity;
        }
        i++;
    }

    printf("Treated Patients: %d\n", treated);
    printf("Rejected Patients: %d", rejected);

    return 0;
}
