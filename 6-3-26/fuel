#include <stdio.h>
int main() {
     int fuel, n, i = 0;
    scanf("%d", &fuel); 
    scanf("%d", &n);     
    int burn[n];
    for(int j = 0; j < n; j++) {
        scanf("%d", &burn[j]);
    }
    while(i < n) {
        fuel = fuel - burn[i];
        if(fuel < 0) {
            printf("Emergency Stage: %d\n", i + 1);
            printf("Fuel Wasted: %d\n", -fuel);
            return 0;
        }
        i++;
    }
    return 0;
} 
