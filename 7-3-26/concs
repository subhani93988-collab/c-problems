#include <stdio.h>
int main() {
      int n, arr[100];
    int i = 0, fail = 0, consec = 0, lock = -1;
    scanf("%d",&n);
    while(i < n){
        scanf("%d",&arr[i]);
        if(arr[i] == 0){
            fail++;
            consec++;
            if(consec == 3 && lock == -1)
                lock = i + 1;
        }
        else
            consec = 0;
  i++;
    }
    if(lock == -1)
        printf("Lock Triggered At Attempt: Not Locked\n");
    else
        printf("Lock Triggered At Attempt: %d\n", lock);
    printf("Total Failed Attempts: %d", fail);

    
    return 0;
}
