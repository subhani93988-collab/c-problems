#include <stdio.h>
int main() {
    int capacity, n, load[100];
    int i = 0, safe = 0, failure = 0;
    scanf("%d", &capacity);
    scanf("%d", &n);
    while(i < n){
        scanf("%d", &load[i]);
        if(load[i] > capacity)
            failure++;
        else
            safe++;
        i++;
    }
    printf("Safe Hours: %d\n", safe);
    printf("Failure Count: %d", failure);
    return 0;
}
