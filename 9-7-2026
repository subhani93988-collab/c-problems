#include <stdio.h>
int main() {
     int capacity, n;
    int load;
    int safeHours = 0, failureCount = 0;
    scanf("%d", &capacity);
    scanf("%d", &n);
    for(int i = 0; i < n; i++) {
        scanf("%d", &load);
        if(load <= capacity) {
            safeHours++;
        } else {
            failureCount++;
        }
    }
    printf("Safe Hours: %d\n", safeHours);
    printf("Failure Count: %d\n", failureCount);
    return 0;
}
