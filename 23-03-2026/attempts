#include <stdio.h>

int main(){
    int n, arr[100];
    int i = 0, high = 0, consec = 0, fraud = -1;

    scanf("%d",&n);

    while(i < n){
        scanf("%d",&arr[i]);

        if(arr[i] >= 50000){
            high++;
            consec++;

            if(consec == 3 && fraud == -1)
                fraud = i + 1;
        }
        else
            consec = 0;

        i++;
    }

    if(fraud == -1)
        printf("Fraud Triggered At Attempt: Not Triggered\n");
    else
        printf("Fraud Triggered At Attempt: %d\n", fraud);

    printf("High-Value Transactions: %d", high);

    return 0;
}
